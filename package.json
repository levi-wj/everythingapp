{
	"name": "everythingapp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"db": "npx supabase start",
		"dbtypes": "npx supabase gen types typescript --local > ./src/lib/database.types.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@dayflow/core": "^3.6.5",
		"@dayflow/plugin-sidebar": "^1.5.5",
		"@dayflow/svelte": "^3.6.5",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.108.2",
		"date-fns": "^4.4.0",
		"rrule": "^2.8.1"
	}
}
